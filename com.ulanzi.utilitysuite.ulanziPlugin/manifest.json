{
  "Author": "Local prototype",
  "Name": "Ulanzi Utility Suite",
  "Description": "Personal Ulanzi Deck utility suite with tools for Windows workflows.",
  "Version": "0.1.0",
  "UUID": "com.ulanzi.ulanzistudio.utilitysuite",
  "Type": "JavaScript",
  "CodePath": "plugin/app.js",
  "Icon": "resources/actions/toggle/on.svg",
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Software": {
    "MinVersion": "3.0.11"
  },
  "Actions": [
    {
      "Name": "Monitor Toggle",
      "UUID": "com.ulanzi.ulanzistudio.utilitysuite.monitortoggle",
      "Icon": "resources/actions/toggle/on.svg",
      "Tooltip": "Toggle a Windows monitor or monitor group",
      "SupportedInMultiActions": false,
      "Controllers": [
        "Keypad"
      ],
      "Devices": [
        "D200H"
      ],
      "PropertyInspectorPath": "property-inspector/monitor-toggle.html",
      "DisableAutomaticStates": true,
      "States": [
        {
          "Name": "Active",
          "Image": "resources/actions/toggle/on.svg",
          "Title": "On"
        },
        {
          "Name": "Inactive",
          "Image": "resources/actions/toggle/off.svg",
          "Title": "Off"
        }
      ]
    }
  ]
}
