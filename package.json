{
  "name": "ulanzi-utility-suite-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:plugin": "npm install --prefix .\\com.ulanzi.utilitysuite.ulanziPlugin",
    "validate:json": "node -e \"const fs=require('fs'); ['package.json','com.ulanzi.utilitysuite.ulanziPlugin/manifest.json','com.ulanzi.utilitysuite.ulanziPlugin/package.json'].forEach((file)=>JSON.parse(fs.readFileSync(file,'utf8'))); console.log('json ok')\"",
    "backend:list": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\com.ulanzi.utilitysuite.ulanziPlugin\\scripts\\WindowsDisplayControl.ps1 -Action list",
    "node:list": "node .\\com.ulanzi.utilitysuite.ulanziPlugin\\plugin\\app.js --list-displays",
    "ai-allowance:codex": "node .\\com.ulanzi.utilitysuite.ulanziPlugin\\plugin\\app.js --ai-allowance-status codex",
    "ai-allowance:claude": "node .\\com.ulanzi.utilitysuite.ulanziPlugin\\plugin\\app.js --ai-allowance-status claude",
    "restart-ulanzi:dry-run": "node .\\com.ulanzi.utilitysuite.ulanziPlugin\\plugin\\app.js --restart-ulanzi-dry-run",
    "restart-ulanzi:launch-dry-run": "node .\\com.ulanzi.utilitysuite.ulanziPlugin\\plugin\\app.js --restart-ulanzi-launch-dry-run",
    "test:ai-allowance": "node --test .\\tests\\ai-allowance.test.js"
  }
}
